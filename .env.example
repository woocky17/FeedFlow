# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/feedflow"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Cron job secret (sólo lo usa /api/cron/backfill, el worker no lo necesita)
CRON_SECRET=""

# Worker — intervalos en segundos
SYNC_INTERVAL_SECONDS=7200
NOTIFICATIONS_INTERVAL_SECONDS=86400

# Backfill histórico: tope de días hacia atrás por llamada a /api/cron/backfill
BACKFILL_MAX_DAYS=3

# Resend (email)
RESEND_API_KEY=""

# Groq (LLM for article classification)
GROQ_API_KEY=""
