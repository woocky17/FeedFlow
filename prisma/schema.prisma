generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum CategoryType {
  DEFAULT
  CUSTOM
}

enum AssignmentOrigin {
  AUTO
  MANUAL
}

// ─── User ────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  categories          Category[]
  categoryAssignments CategoryAssignment[]
  favorites           Favorite[]
  notifications       Notification[]
  stories             Story[]

  @@map("users")
}

// ─── Source ──────────────────────────────────────────────

model Source {
  id        String   @id @default(cuid())
  name      String
  baseUrl   String
  apiKey    String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  articles Article[]

  @@map("sources")
}

// ─── Article ─────────────────────────────────────────────

model Article {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  description String?
  image       String?
  sourceId    String
  publishedAt DateTime
  savedAt     DateTime @default(now())
  embedding   Float[]  @default([])

  source              Source               @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  categoryAssignments CategoryAssignment[]
  favorites           Favorite[]
  storyArticles       StoryArticle[]
  storySources        Story[]              @relation("StorySource")

  @@index([sourceId])
  @@index([publishedAt])
  @@map("articles")
}

// ─── Category ────────────────────────────────────────────

model Category {
  id        String       @id @default(cuid())
  name      String
  type      CategoryType @default(DEFAULT)
  userId    String?
  createdAt DateTime     @default(now())

  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryAssignments CategoryAssignment[]

  @@unique([name, userId])
  @@index([userId])
  @@map("categories")
}

// ─── CategoryAssignment ──────────────────────────────────

model CategoryAssignment {
  id         String           @id @default(cuid())
  articleId  String
  categoryId String
  userId     String?
  origin     AssignmentOrigin @default(AUTO)
  assignedAt DateTime         @default(now())

  article  Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([articleId, categoryId, userId])
  @@index([articleId])
  @@index([categoryId])
  @@map("category_assignments")
}

// ─── Favorite ────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("favorites")
}

// ─── Notification ────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ─── Story ───────────────────────────────────────────────

model Story {
  id              String   @id @default(cuid())
  userId          String
  name            String
  summary         String
  embedding       Float[]  @default([])
  sourceArticleId String
  threshold       Float    @default(0.55)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceArticle Article        @relation("StorySource", fields: [sourceArticleId], references: [id], onDelete: Cascade)
  articles      StoryArticle[]

  @@unique([userId, sourceArticleId])
  @@index([userId])
  @@index([active])
  @@map("stories")
}

// ─── StoryArticle ────────────────────────────────────────

model StoryArticle {
  id         String   @id @default(cuid())
  storyId    String
  articleId  String
  similarity Float
  addedAt    DateTime @default(now())

  story   Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([storyId, articleId])
  @@index([storyId])
  @@index([articleId])
  @@map("story_articles")
}
